<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mis Tareas ✨</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:        #fff0f5;
  --surface:   #ffffff;
  --border:    #f4b8ce;
  --text:      #2d0a1a;
  --text2:     #8a3a58;
  --text3:     #c490a8;
  --pink:      #e0186a;
  --pink-deep: #b50052;
  --pink-soft: #fddceb;
  --gold:      #c8890a;
  --gold-bg:   #fff3d0;
  --done-c:    #1a7a3f;
  --done-bg:   #d6f5e3;
  --r: 20px;
  --r-sm: 12px;
  --r-pill: 100px;
}

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    radial-gradient(circle, #f48ab5 1.5px, transparent 1.5px),
    radial-gradient(circle, #fdd5e8 1px, transparent 1px),
    radial-gradient(circle, #fbc9dc 1px, transparent 1px);
  background-size: 60px 60px, 40px 40px, 90px 90px;
  background-position: 0 0, 20px 30px, 50px 10px;
  opacity: .25;
  pointer-events: none;
  z-index: 0;
}

.wrap { position: relative; z-index: 1; }

header {
  text-align: center;
  padding: 56px 24px 40px;
}

.sparkles { font-size: 22px; letter-spacing: 8px; display: block; margin-bottom: 12px; color: var(--pink); }

header h1 {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(32px, 6vw, 52px);
  font-weight: 700;
  color: var(--pink);
  letter-spacing: -0.5px;
  line-height: 1.15;
}

header h1 em { font-style: italic; color: var(--text); }
header p { font-size: 13px; color: var(--text3); margin-top: 10px; font-weight: 300; letter-spacing: .4px; }

/* estado de carga */
.status-bar {
  text-align: center;
  font-size: 12px;
  color: var(--text3);
  margin-bottom: 8px;
  min-height: 18px;
  transition: opacity .3s;
}

.add-wrap { max-width: 640px; margin: 0 auto 48px; padding: 0 20px; }

.add-card {
  background: var(--surface);
  border: 2px solid var(--border);
  border-radius: var(--r-pill);
  padding: 6px 6px 6px 24px;
  display: flex;
  align-items: center;
  gap: 10px;
  transition: border-color .2s, box-shadow .2s;
}

.add-card:focus-within {
  border-color: var(--pink);
  box-shadow: 0 0 0 4px rgba(224,24,106,.12);
}

.add-card input[type="text"] {
  flex: 1;
  border: none;
  background: transparent;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  color: var(--text);
  outline: none;
  min-width: 0;
}

.add-card input[type="text"]::placeholder { color: var(--text3); font-weight: 300; }

.priority-pill {
  display: flex;
  align-items: center;
  gap: 5px;
  background: var(--pink-soft);
  border-radius: var(--r-pill);
  padding: 6px 12px;
  flex-shrink: 0;
}

.priority-pill label { font-size: 11px; font-weight: 600; color: var(--pink); letter-spacing: .5px; text-transform: uppercase; white-space: nowrap; }

.priority-pill input[type="number"] {
  width: 26px;
  border: none;
  background: transparent;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 600;
  color: var(--pink-deep);
  outline: none;
  text-align: center;
}

.add-btn {
  background: var(--pink);
  color: #fff;
  border: none;
  border-radius: var(--r-pill);
  padding: 12px 24px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: background .15s, box-shadow .15s, transform .1s;
}

.add-btn:hover { background: var(--pink-deep); box-shadow: 0 4px 16px rgba(224,24,106,.35); }
.add-btn:active { transform: scale(.97); }
.add-btn:disabled { opacity: .6; cursor: not-allowed; }

.board {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 20px 64px;
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 20px;
}

@media(max-width:720px){ .board { grid-template-columns:1fr; } }

.column {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
}

.col-header {
  padding: 20px 20px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 3px solid transparent;
}

.col-todo .col-header { border-bottom-color: var(--pink); }
.col-prog .col-header { border-bottom-color: var(--gold); }
.col-done .col-header { border-bottom-color: var(--done-c); }

.col-label { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700; color: var(--text); }
.col-todo .col-label { color: var(--pink); }
.col-prog .col-label { color: var(--gold); }
.col-done .col-label { color: var(--done-c); }

.col-count { font-size: 11px; font-weight: 600; letter-spacing: .5px; padding: 3px 10px; border-radius: var(--r-pill); }
.col-todo .col-count { background: var(--pink-soft); color: var(--pink-deep); }
.col-prog .col-count { background: var(--gold-bg);   color: var(--gold); }
.col-done .col-count { background: var(--done-bg);   color: var(--done-c); }

.task-list { padding: 14px; display: flex; flex-direction: column; gap: 8px; min-height: 100px; }

.empty-msg { text-align: center; font-size: 12px; font-weight: 300; color: var(--text3); padding: 16px 0 8px; font-style: italic; }

.task {
  border-radius: var(--r-sm);
  padding: 13px 14px;
  display: flex;
  align-items: flex-start;
  gap: 10px;
  cursor: grab;
  border: 1.5px solid transparent;
  background: var(--bg);
  transition: border-color .15s, box-shadow .15s;
  user-select: none;
}

.task:hover { border-color: var(--border); box-shadow: 0 2px 12px rgba(224,24,106,.08); }
.task:active { cursor: grabbing; opacity: .6; }
.task.dragging { opacity: .3; }

.chip {
  flex-shrink: 0;
  height: 24px;
  min-width: 28px;
  padding: 0 8px;
  border-radius: var(--r-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  cursor: pointer;
  transition: filter .15s, transform .1s;
  margin-top: 1px;
  letter-spacing: .3px;
}

.chip:hover { filter: brightness(.9); transform: scale(1.06); }

.p-high { background: var(--pink);    color: #fff; }
.p-mid  { background: var(--gold-bg); color: var(--gold); border: 1.5px solid #f0d080; }
.p-low  { background: var(--done-bg); color: var(--done-c); }
.p-done { background: #f0f0f0; color: #aaa; }

.task-body { flex: 1; min-width: 0; }
.task-text { font-size: 14px; line-height: 1.55; color: var(--text); word-break: break-word; }
.task-text.done-text { text-decoration: line-through; color: var(--text3); }

.p-editor { display: none; align-items: center; gap: 8px; margin-top: 8px; }
.p-editor.open { display: flex; }
.p-editor-label { font-size: 11px; color: var(--text3); white-space: nowrap; font-weight: 500; }
.p-editor input[type="range"] { flex: 1; accent-color: var(--pink); cursor: pointer; }
.p-val { font-size: 11px; font-weight: 700; color: var(--pink); min-width: 14px; text-align: right; }

.task-actions { display: flex; align-items: flex-start; gap: 2px; opacity: 0; transition: opacity .15s; flex-shrink: 0; padding-top: 1px; }
.task:hover .task-actions { opacity: 1; }

.icon-btn {
  background: none;
  border: none;
  cursor: pointer;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  color: var(--text3);
  transition: background .12s, color .12s;
}

.icon-btn:hover { background: var(--pink-soft); color: var(--pink); }
.icon-btn.del:hover { background: #ffe0e8; color: var(--pink-deep); }

footer { text-align: center; padding: 0 0 40px; font-size: 12px; color: var(--text3); font-weight: 300; }
</style>
</head>
<body>
<div class="wrap">

<header>
  <span class="sparkles">✦ ✦ ✦</span>
  <h1>Mis <em>tareas</em></h1>
  <p>Sincronizado con tu bot de Telegram ✨</p>
</header>

<div class="add-wrap">
  <div class="status-bar" id="status-bar"></div>
  <div class="add-card">
    <input type="text" id="new-task" placeholder="¿Qué hay que hacer hoy?" maxlength="200">
    <div class="priority-pill">
      <label for="new-priority">P</label>
      <input type="number" id="new-priority" min="1" max="10" value="5">
    </div>
    <button class="add-btn" id="add-btn" onclick="addTask()">Agregar</button>
  </div>
</div>

<div class="board">
  <div class="column col-todo" ondragover="onDragOver(event)" ondrop="onDrop(event,'todo')">
    <div class="col-header">
      <span class="col-label">Por hacer</span>
      <span class="col-count" id="count-todo">0</span>
    </div>
    <div class="task-list" id="list-todo"></div>
    <div class="empty-msg" id="empty-todo">Nada por aquí… aún</div>
  </div>

  <div class="column col-prog" ondragover="onDragOver(event)" ondrop="onDrop(event,'progress')">
    <div class="col-header">
      <span class="col-label">En progreso</span>
      <span class="col-count" id="count-progress">0</span>
    </div>
    <div class="task-list" id="list-progress"></div>
    <div class="empty-msg" id="empty-progress">Todo en pausa por ahora</div>
  </div>

  <div class="column col-done" ondragover="onDragOver(event)" ondrop="onDrop(event,'done')">
    <div class="col-header">
      <span class="col-label">Hecho</span>
      <span class="col-count" id="count-done">0</span>
    </div>
    <div class="task-list" id="list-done"></div>
    <div class="empty-msg" id="empty-done">Tus logros aparecerán aquí</div>
  </div>
</div>

<footer>Hecho con amor y mucho rosa 🩷</footer>

</div>

<script>
const API = '/api/tasks';
const COLS = ['todo','progress','done'];
let tasks = [];
let dragId = null;
let openPId = null;

function setStatus(msg, ok = true) {
  const bar = document.getElementById('status-bar');
  bar.textContent = msg;
  bar.style.color = ok ? 'var(--text3)' : 'var(--pink)';
}

async function loadTasks() {
  setStatus('Cargando tareas…');
  try {
    const res = await fetch(API);
    if (!res.ok) throw new Error('Error ' + res.status);
    tasks = await res.json();
    setStatus('');
    render();
  } catch(e) {
    setStatus('No se pudo conectar con la base de datos', false);
  }
}

async function addTask() {
  const inp = document.getElementById('new-task');
  const text = inp.value.trim();
  if (!text) return;
  const priority = clamp(document.getElementById('new-priority').value);
  const btn = document.getElementById('add-btn');
  btn.disabled = true;
  setStatus('Guardando…');
  try {
    const res = await fetch(API, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text, priority, status: 'todo' })
    });
    if (!res.ok) throw new Error();
    const task = await res.json();
    tasks.unshift(task);
    inp.value = '';
    setStatus('');
    render();
  } catch(e) {
    setStatus('Error al guardar la tarea', false);
  } finally {
    btn.disabled = false;
    inp.focus();
  }
}

document.getElementById('new-task').addEventListener('keydown', e => {
  if (e.key === 'Enter') addTask();
});

async function moveTask(id, dir) {
  const t = tasks.find(t => t.id === id);
  if (!t) return;
  const i = COLS.indexOf(t.status), ni = i + dir;
  if (ni < 0 || ni >= COLS.length) return;
  const newStatus = COLS[ni];
  t.status = newStatus;
  render();
  try {
    await fetch(`${API}?id=${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: newStatus })
    });
  } catch(e) { setStatus('Error al mover la tarea', false); }
}

async function deleteTask(id) {
  tasks = tasks.filter(t => t.id !== id);
  render();
  try {
    await fetch(`${API}?id=${id}`, { method: 'DELETE' });
  } catch(e) { setStatus('Error al eliminar', false); }
}

async function setPriority(id, val) {
  const t = tasks.find(t => t.id === id);
  if (!t) return;
  t.priority = clamp(val);
  openPId = id;
  render();
  try {
    await fetch(`${API}?id=${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ priority: t.priority })
    });
  } catch(e) { setStatus('Error al actualizar prioridad', false); }
}

function toggleP(id) {
  openPId = openPId === id ? null : id;
  render();
}

function clamp(v) { return Math.min(10, Math.max(1, parseInt(v) || 5)); }

function sorted(items, col) {
  if (col === 'done') return items;
  return [...items].sort((a,b) => (b.priority||5) - (a.priority||5));
}

function chipClass(p, done) {
  if (done) return 'p-done';
  if (p >= 8) return 'p-high';
  if (p >= 4) return 'p-mid';
  return 'p-low';
}

function esc(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function render() {
  COLS.forEach(col => {
    const list  = document.getElementById('list-' + col);
    const empty = document.getElementById('empty-' + col);
    const count = document.getElementById('count-' + col);
    const isDone = col === 'done';
    const items = sorted(tasks.filter(t => t.status === col), col);
    count.textContent = items.length;
    empty.style.display = items.length ? 'none' : 'block';
    list.innerHTML = '';
    const ci = COLS.indexOf(col);

    items.forEach(t => {
      const p = t.priority || 5;
      const isOpen = openPId === t.id;
      const div = document.createElement('div');
      div.className = 'task';
      div.draggable = true;
      div.dataset.id = t.id;
      div.addEventListener('dragstart', () => { dragId = t.id; div.classList.add('dragging'); });
      div.addEventListener('dragend',   () => div.classList.remove('dragging'));

      div.innerHTML = `
        <div class="chip ${chipClass(p,isDone)}" title="Prioridad ${p}" onclick="toggleP(${t.id})">${p}</div>
        <div class="task-body">
          <div class="task-text ${isDone?'done-text':''}">${esc(t.text)}</div>
          <div class="p-editor ${isOpen?'open':''}">
            <span class="p-editor-label">Prioridad</span>
            <input type="range" min="1" max="10" step="1" value="${p}"
              oninput="this.nextElementSibling.textContent=this.value"
              onchange="setPriority(${t.id},this.value)">
            <span class="p-val">${p}</span>
          </div>
        </div>
        <div class="task-actions">
          ${ci > 0 ? `<button class="icon-btn" onclick="moveTask(${t.id},-1)" title="Atrás">←</button>` : ''}
          ${ci < 2  ? `<button class="icon-btn" onclick="moveTask(${t.id},1)"  title="Adelante">→</button>` : ''}
          <button class="icon-btn del" onclick="deleteTask(${t.id})" title="Eliminar">✕</button>
        </div>`;
      list.appendChild(div);
    });
  });
}

function onDragOver(e) { e.preventDefault(); }

function onDrop(e, col) {
  e.preventDefault();
  if (!dragId) return;
  const t = tasks.find(t => t.id === dragId);
  if (t && t.status !== col) {
    t.status = col;
    render();
    fetch(`${API}?id=${dragId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: col })
    }).catch(() => setStatus('Error al mover la tarea', false));
  }
  dragId = null;
}

loadTasks();
setInterval(loadTasks, 30000);
</script>
</body>
</html>
